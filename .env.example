# Copy this file to .env (which is gitignored) and fill in your values.
#
# DATABASE_URL — your Supabase Postgres connection string.
#   Supabase dashboard -> Connect (top bar) -> choose "Session pooler" -> copy URI.
#   IMPORTANT: use the SESSION pooler (port 5432) or the direct connection, NOT the
#   Transaction pooler (port 6543). extract_citations.py uses a server-side cursor
#   for the big scan, which requires a session-mode connection.
DATABASE_URL=postgresql://postgres.<project-ref>:<YOUR_PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require

# OPENAI_API_KEY — used by app.py and incremental_index_pgvector.py.
#   NOT needed by extract_citations.py (it does no embedding).
OPENAI_API_KEY=sk-...
